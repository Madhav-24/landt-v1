APP_NAME=Larsen & Toubro AI Road Safety Platform
APP_ENV=development
DEBUG=true
API_PREFIX=/api
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=240
DATABASE_URL=postgresql://lt_user:lt_password@127.0.0.1:5432/lt_platform
MEDIA_ROOT=/var/lib/lt-platform/media
ALLOWED_ORIGINS=http://localhost:5173
